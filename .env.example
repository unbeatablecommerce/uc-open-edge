# UC Open Edge - Environment Variables
# Copy this file to .env and fill in your own values before starting.
#
# WARNING: Do NOT use these example credentials in production.
#          Do NOT commit your real .env file to version control.
#          The .gitignore already excludes .env — keep it that way.
#          Generate a strong SESSION_SECRET with: openssl rand -hex 32

# --- Node Environment ---
NODE_ENV=development

# --- Database ---
# Required. Must point to a running PostgreSQL instance.
DATABASE_URL=postgresql://ucedge:ucedge@localhost:5432/ucedge

# --- Admin user seed ---
# Set both before running `pnpm db:seed` to create the initial admin user.
# If not set, seed will print instructions and exit safely (no insecure defaults).
ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=changeme-secure-password-here

# --- Session security ---
# Must be a long random string (32+ chars). Generate with: openssl rand -hex 32
SESSION_SECRET=replace-this-with-a-random-64-char-hex-string-before-use

# --- Service ports ---
API_PORT=3001
ADMIN_PORT=3000

# --- Logging ---
# Levels: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- File drop connector ---
# Root directory where file-drop connector watches for incoming files.
FILE_DROP_ROOT=/var/uc-open-edge/file-drop

# --- CORS ---
# Comma-separated list of allowed origins for the API (admin SvelteKit origin).
CORS_ORIGINS=http://localhost:3000

# --- MQTT (optional) ---
# Only needed if using the MQTT connector or destination.
# MQTT_BROKER_URL=mqtt://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
